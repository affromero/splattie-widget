{
  "name": "@affromero/splattie-widget",
  "version": "0.1.0",
  "description": "Interactive 3D Gaussian Splatting web component — like Rive/Lottie for 3D",
  "type": "module",
  "main": "dist/splattie-widget.umd.cjs",
  "module": "dist/splattie-widget.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/splattie-widget.js",
      "require": "./dist/splattie-widget.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "gaussian-splatting",
    "3dgs",
    "web-component",
    "flame",
    "avatar",
    "interactive",
    "splattie"
  ],
  "author": "Andres Romero <me@afromero.co>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/affromero/splattie.git",
    "directory": "packages/splattie-widget"
  },
  "license": "MIT",
  "dependencies": {
    "@sparkjsdev/spark": "^2.0.0",
    "jszip": "^3.10.1",
    "three": ">=0.180.0"
  },
  "devDependencies": {
    "@types/three": "^0.180.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vitest": "^3.1.0"
  },
  "peerDependencies": {
    "three": ">=0.180.0"
  }
}
